datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  SUPER_ADMIN
  ORGANIZATION_ADMIN
  EMPLOYEE
}

enum UserType {
  INTERNAL // Employee
  EXTERNAL // Contractor / Partner
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

enum VehicleVerificationStatus {
  PENDING
  VERIFIED
  SUSPENDED
  REJECTED
}

enum RideStatus {
  DRAFT
  OPEN
  FULL
  STARTED
  COMPLETED
  CANCELLED
  EXPIRED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED
  NO_SHOW
  EXPIRED
}

enum TripStatus {
  BOOKED
  STARTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CARD
  UPI
  WALLET
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  ESCROWED
  REFUNDED
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  CREDIT
  DEBIT
  REFUND
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

enum RatingType {
  DRIVER_TO_PASSENGER
  PASSENGER_TO_DRIVER
}

enum ParticipantRole {
  DRIVER
  PASSENGER
}

enum NotificationPriority {
  INFO
  WARNING
  SUCCESS
  ERROR
}

enum NotificationChannel {
  PUSH
  EMAIL
  SMS
  IN_APP
}

model Organization {
  id               String   @id @default(uuid()) @db.Uuid
  name             String
  code             String   @unique
  logo             String?
  emailDomain      String?
  address          String
  city             String
  state            String
  country          String
  status           String   @default("ACTIVE")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deletedAt        DateTime? // Soft delete support

  users            User[]
  rides            Ride[]

  @@index([code])
}

model User {
  id               String     @id @default(uuid()) @db.Uuid
  organizationId   String?    @db.Uuid // Nullable ONLY for SUPER_ADMIN
  employeeCode     String?
  firstName        String
  lastName         String
  email            String     @unique
  phone            String
  passwordHash     String
  role             UserRole   @default(EMPLOYEE)
  userType         UserType   @default(INTERNAL)
  status           UserStatus @default(ACTIVE)
  avatar           String?
  isEmailVerified  Boolean    @default(false)
  isPhoneVerified  Boolean    @default(false)
  lastLogin        DateTime?
  refreshTokenHash String?
  deviceToken      String?
  loginProvider    String     @default("LOCAL")
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  deletedAt        DateTime?

  organization     Organization? @relation(fields: [organizationId], references: [id])
  wallet           Wallet?
  vehicles         Vehicle[]
  ridesAsDriver    Ride[]
  bookings         Booking[]
  notifications    Notification[]
  messages         Message[]
  participants     TripParticipant[]
  auditLogs        AuditLog[]
  transactions     WalletTransaction[]
  payments         Payment[]
  driverSettlements DriverSettlement[]
  withdrawalRequests WithdrawalRequest[]
  ratingsGiven     Rating[]          @relation("RatingsGiven")
  ratingsReceived  Rating[]          @relation("RatingsReceived")

  @@index([email, organizationId])
}

model Wallet {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @unique @db.Uuid
  availableBalance Decimal  @default(0.0) @db.Decimal(10, 2)
  pendingEarnings Decimal  @default(0.0) @db.Decimal(10, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]
}

model WalletTransaction {
  id               String          @id @default(uuid()) @db.Uuid
  walletId         String          @db.Uuid
  userId           String          @db.Uuid
  type             TransactionType
  amount           Decimal         @db.Decimal(10, 2)
  relatedPaymentId String?         @db.Uuid
  description      String?
  createdAt        DateTime        @default(now())

  wallet         Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  relatedPayment Payment? @relation(fields: [relatedPaymentId], references: [id], onDelete: SetNull)

  @@index([walletId, createdAt])
}

model Vehicle {
  id                 String                    @id @default(uuid()) @db.Uuid
  ownerId            String                    @db.Uuid
  manufacturer       String
  model              String
  color              String
  registrationNumber String                    @unique
  seatingCapacity    Int
  verificationStatus VehicleVerificationStatus @default(PENDING)
  insuranceExpiry    DateTime?
  pollutionExpiry    DateTime?
  vehiclePhoto       String?
  isActive           Boolean                   @default(true)
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  deletedAt          DateTime?

  owner User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  rides Ride[]

  @@index([ownerId])
}

model Ride {
  id                   String     @id @default(uuid()) @db.Uuid
  organizationId       String     @db.Uuid // Scoped for trust/display
  driverId             String     @db.Uuid
  vehicleId            String     @db.Uuid
  pickupAddress        String
  pickupLat            Decimal    @db.Decimal(10, 8)
  pickupLng            Decimal    @db.Decimal(11, 8)
  pickupPlaceId        String?
  destinationAddress   String
  destinationLat       Decimal    @db.Decimal(10, 8)
  destinationLng       Decimal    @db.Decimal(11, 8)
  destinationPlaceId   String?
  routePolyline        String     @db.Text
  routeDistanceMeters  Int
  routeDurationSeconds Int
  estimatedFuelCost    Decimal    @db.Decimal(10, 2)
  date                 DateTime   @db.Date
  time                 String
  availableSeats       Int
  farePerSeat          Decimal    @db.Decimal(10, 2)
  recurring            Boolean    @default(false)
  status               RideStatus @default(OPEN)
  vehicleType          String?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  deletedAt            DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  driver       User         @relation(fields: [driverId], references: [id], onDelete: Cascade)
  vehicle      Vehicle      @relation(fields: [vehicleId], references: [id])
  bookings     Booking[]
  trip         Trip?

  @@index([organizationId, date, status])
  @@index([driverId])
}

model Booking {
  id               String        @id @default(uuid()) @db.Uuid
  bookingReference String        @unique
  rideId           String        @db.Uuid
  passengerId      String        @db.Uuid
  seatsBooked      Int
  status           BookingStatus @default(PENDING)
  fare             Decimal       @db.Decimal(10, 2)
  cancelReason     String?
  approvedBy       String?       @db.Uuid
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  ride      Ride      @relation(fields: [rideId], references: [id], onDelete: Cascade)
  passenger User      @relation(fields: [passengerId], references: [id], onDelete: Cascade)
  payments  Payment[]

  @@index([rideId])
  @@index([passengerId])
}

model Trip {
  id                  String     @id @default(uuid()) @db.Uuid
  rideId              String     @unique @db.Uuid
  status              TripStatus @default(BOOKED)
  startedAt           DateTime?
  completedAt         DateTime?
  actualStartLocation String?
  actualEndLocation   String?
  actualDistance      Decimal?   @db.Decimal(10, 2)
  averageSpeed        Decimal?   @db.Decimal(5, 2)
  endedBy             String?    @db.Uuid
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  ride         Ride                  @relation(fields: [rideId], references: [id], onDelete: Cascade)
  conversation Conversation?
  participants TripParticipant[]
  history      TripLocationHistory[]
  payments     Payment[]
  settlements  DriverSettlement[]
  ratings      Rating[]

  @@index([status])
}

model TripParticipant {
  id        String          @id @default(uuid()) @db.Uuid
  tripId    String          @db.Uuid
  userId    String          @db.Uuid
  role      ParticipantRole
  createdAt DateTime        @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tripId, userId])
}

model TripLocationHistory {
  id        String   @id @default(uuid()) @db.Uuid
  tripId    String   @db.Uuid
  lat       Decimal  @db.Decimal(10, 8)
  lng       Decimal  @db.Decimal(11, 8)
  heading   Decimal? @db.Decimal(5, 2)
  speed     Decimal? @db.Decimal(5, 2)
  accuracy  Decimal? @db.Decimal(5, 2)
  timestamp DateTime @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId, timestamp])
}

model Payment {
  id               String        @id @default(uuid()) @db.Uuid
  tripId           String?       @db.Uuid
  bookingId        String        @db.Uuid
  payerId          String        @db.Uuid
  amount           Decimal       @db.Decimal(10, 2)
  method           PaymentMethod
  status           PaymentStatus @default(PENDING)
  gatewayOrderId   String?
  gatewayPaymentId String?
  gatewaySignature String?
  failureReason    String?
  currency         String        @default("INR")
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  trip              Trip?               @relation(fields: [tripId], references: [id], onDelete: Cascade)
  booking           Booking             @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  payer             User                @relation(fields: [payerId], references: [id], onDelete: Cascade)
  walletTransaction WalletTransaction[]

  @@index([tripId])
  @@index([bookingId])
}

model DriverSettlement {
  id               String   @id @default(uuid()) @db.Uuid
  driverId         String   @db.Uuid
  tripId           String   @db.Uuid
  grossFare        Decimal  @db.Decimal(10, 2)
  commissionAmount Decimal  @db.Decimal(10, 2)
  netEarnings      Decimal  @db.Decimal(10, 2)
  status           String   @default("PENDING") // PENDING, SETTLED
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  driver User @relation(fields: [driverId], references: [id], onDelete: Cascade)
  trip   Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([driverId])
  @@index([tripId])
}

model WithdrawalRequest {
  id                   String           @id @default(uuid()) @db.Uuid
  userId               String           @db.Uuid
  amount               Decimal          @db.Decimal(10, 2)
  bankAccountDetails   String
  status               WithdrawalStatus @default(PENDING)
  transactionReference String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Rating {
  id          String     @id @default(uuid()) @db.Uuid
  tripId      String     @db.Uuid
  reviewerId  String     @db.Uuid
  revieweeId  String     @db.Uuid
  rating      Int
  reviewText  String?    @db.Text
  type        RatingType
  createdAt   DateTime   @default(now())

  trip     Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  reviewer User @relation("RatingsGiven", fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewee User @relation("RatingsReceived", fields: [revieweeId], references: [id], onDelete: Cascade)

  @@index([reviewerId])
  @@index([revieweeId])
}

model Conversation {
  id        String   @id @default(uuid()) @db.Uuid
  tripId    String   @unique @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trip     Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  messages Message[]
}

model Message {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @db.Uuid
  senderId       String   @db.Uuid
  content        String   @db.Text
  read           Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model Notification {
  id        String                 @id @default(uuid()) @db.Uuid
  userId    String                 @db.Uuid
  title     String
  body      String
  priority  NotificationPriority   @default(INFO)
  channel   NotificationChannel    @default(IN_APP)
  read      Boolean                @default(false)
  createdAt DateTime               @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @db.Uuid
  action     String
  entityName String?
  entityId   String?  @db.Uuid
  oldValues  String?  @db.Text // JSON string representation
  newValues  String?  @db.Text // JSON string representation
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, action, createdAt])
}
