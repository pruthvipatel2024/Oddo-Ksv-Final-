# ==========================================
# Frontend Environment Configuration Example
# ==========================================

# Base REST API URL of the NestJS server.
# REQUIRED: Yes
# DEFAULT: http://localhost:5000/api/v1
# ENVIRONMENTS: local, development, production, test
# PURPOSE: Interacting with the backend services.
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000/api/v1

# Base Socket.io server connection URL.
# REQUIRED: Yes
# DEFAULT: http://localhost:5000
# ENVIRONMENTS: local, development, production, test
# PURPOSE: Live tracking coordinates streaming and chat events namespace.
NEXT_PUBLIC_WS_URL=http://localhost:5000

# Google Maps Platform Javascript API Key.
# REQUIRED: No (optional for fallback rendering)
# DEFAULT: 
# ENVIRONMENTS: local, development, production
# PURPOSE: Visualizing route confirmation screens on the map canvas.
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# Razorpay Sandbox payment key identifier.
# REQUIRED: Yes (for checkout checkout sandbox)
# DEFAULT: rzp_test_placeholder_key
# ENVIRONMENTS: local, development, staging
# PURPOSE: Opening test checkout sandbox forms for employee wallet recharge.
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_placeholder_key
