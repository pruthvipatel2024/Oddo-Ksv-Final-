# Core Configuration
PORT=5000
NODE_ENV=development

# Supabase Configurations
# Replace with your Supabase Project URL and API keys (found in Project Settings > API)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# JWT Secret (if running custom Express/Node auth validation)
JWT_SECRET=your_jwt_secret_minimum_32_characters

# Maps & Routing Configurations
# Google Maps API Key for Directions & Places APIs
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Payment Sandbox Configuration
# Razorpay Test Mode keys (found in Dashboard > Settings > API Keys)
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
